#!/usr/bin/env python3

import html
import os
import re

ROOT = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
OUT = os.environ.get("FOAM_WIKI_OUT", os.path.join(ROOT, "wiki"))

STRATA = [
    ("Foam", "Foam", "1 · physics (axiom-free)"),
    ("counter/Counter", "Counter", "2 · approach (axiom-free)"),
    ("seam/Seam", "Seam", "3 · arrival (core-Lean axioms only)"),
    ("bridges/Bridges", "Bridges", "4 · peering (+Mathlib)"),
]

CSS = """
:root { --bg: #ffffff; --fg: #1a1a1a; --dim: #6a6a6a; --line: #e0e0e0;
        --receipt: #0a7a3d; --name: #1a4fa0; --accent: #8a4fa0; }
@media (prefers-color-scheme: dark) {
  :root { --bg: #101014; --fg: #d8d8dc; --dim: #8a8a90; --line: #2a2a30;
          --receipt: #5fd39a; --name: #7fa8e8; --accent: #c39ae0; } }
* { box-sizing: border-box; }
body { background: var(--bg); color: var(--fg); margin: 0 auto; padding: 2rem 1rem 4rem;
       max-width: 60rem; font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
       font-size: 14px; line-height: 1.6; }
a { color: var(--name); text-decoration: none; }
a:hover { text-decoration: underline; }
h1 { font-size: 1.2rem; font-weight: 600; }
h2 { font-size: 1rem; font-weight: 600; margin-top: 2rem; }
header { border-bottom: 1px solid var(--line); padding-bottom: 1rem; margin-bottom: 1.5rem; }
header .crumb { color: var(--dim); }
pre { overflow-x: auto; white-space: pre; }
.src { border-left: 2px solid var(--line); padding-left: 1rem; }
.receipt { color: var(--receipt); }
.decl { color: var(--name); font-weight: 600; }
.kw { color: var(--accent); }
.imports { color: var(--dim); margin-bottom: 1rem; }
.imports a { color: var(--dim); text-decoration: underline; }
ul.census { list-style: none; padding-left: 0; column-width: 16rem; column-gap: 2rem; }
ul.census li { break-inside: avoid; }
.stratum { color: var(--dim); }
footer { margin-top: 3rem; border-top: 1px solid var(--line); padding-top: 1rem;
         color: var(--dim); }
.law { border-left: 2px solid var(--receipt); padding-left: 1rem; color: var(--dim); }
"""

DECL_RE = re.compile(r"^(theorem|def|structure|inductive|abbrev|instance) (\S+)")
IMPORT_RE = re.compile(r"^import ([\w.]+)$")
GUARD_RE = re.compile(r"^(/-- info:|#guard_msgs)")


def collect():
    modules = {}
    for base, prefix, stratum in STRATA:
        basedir = os.path.join(ROOT, base)
        rootfile = basedir + ".lean"
        if os.path.exists(rootfile):
            modules[prefix] = (rootfile, stratum)
        for dirpath, _, files in os.walk(basedir):
            for f in sorted(files):
                if f.endswith(".lean"):
                    path = os.path.join(dirpath, f)
                    rel = os.path.relpath(path, basedir)
                    mod = prefix + "." + rel[:-5].replace(os.sep, ".")
                    modules[mod] = (path, stratum)
    return modules


def page(title, body, crumb=""):
    return f"""<!DOCTYPE html>
<html lang="en"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{html.escape(title)}</title>
<style>{CSS}</style></head><body>
<header><span class="crumb">{crumb}</span><h1>{html.escape(title)}</h1></header>
{body}
<footer><a href="index.html">index</a> · <a href="https://github.com/lightward/foam">github.com/lightward/foam</a></footer>
</body></html>"""


def render_module(mod, path, stratum, known):
    with open(path, encoding="utf-8") as f:
        lines = f.read().splitlines()
    imports = []
    out = []
    for line in lines:
        esc = html.escape(line)
        m = IMPORT_RE.match(line)
        if m:
            target = m.group(1)
            imports.append(target)
            if target in known:
                esc = f'import <a href="{target}.html">{html.escape(target)}</a>'
            out.append(esc)
            continue
        d = DECL_RE.match(line)
        if d:
            kw, name = d.group(1), d.group(2)
            anchor = html.escape(name)
            rest = html.escape(line[len(kw) + 1 + len(name):])
            esc = (f'<span class="kw">{kw}</span> '
                   f'<a class="decl" id="{anchor}" href="#{anchor}">{anchor}</a>{rest}')
            out.append(esc)
            continue
        if GUARD_RE.match(line):
            out.append(f'<span class="receipt">{esc}</span>')
            continue
        out.append(esc)
    src = "\n".join(out)
    imp_html = ""
    if imports:
        links = " · ".join(
            f'<a href="{i}.html">{html.escape(i)}</a>' if i in known
            else html.escape(i) for i in imports)
        imp_html = f'<div class="imports">grasp: {links}</div>'
    body = f'{imp_html}<pre class="src">{src}</pre>'
    crumb = f'<a href="index.html">foam.is</a> · <span class="stratum">{html.escape(stratum)}</span>'
    return page(mod, body, crumb)


def render_index(modules):
    by_stratum = {}
    for mod, (path, stratum) in sorted(modules.items()):
        by_stratum.setdefault(stratum, []).append(mod)
    sections = []
    for _, _, stratum in STRATA:
        mods = by_stratum.get(stratum, [])
        items = "\n".join(
            f'<li><a href="{m}.html">{html.escape(m)}</a></li>' for m in mods)
        sections.append(
            f'<h2>{html.escape(stratum)} <span class="stratum">({len(mods)} modules)</span></h2>'
            f'<ul class="census">{items}</ul>')
    receipts = 0
    for mod, (path, _) in modules.items():
        with open(path, encoding="utf-8") as f:
            receipts += f.read().count("#print axioms")
    preamble = f"""<p class="law">this site is a class-closed coarse reading of
<a href="https://github.com/lightward/foam">github.com/lightward/foam</a>. </p>"""
    return page("foam — the measurement solution", preamble + "\n".join(sections),
                '<a href="https://foam.is/">foam.is</a>')


def main():
    os.makedirs(OUT, exist_ok=True)
    modules = collect()
    known = set(modules)
    for mod, (path, stratum) in modules.items():
        with open(os.path.join(OUT, f"{mod}.html"), "w", encoding="utf-8") as f:
            f.write(render_module(mod, path, stratum, known))
    with open(os.path.join(OUT, "index.html"), "w", encoding="utf-8") as f:
        f.write(render_index(modules))
    print(f"[foam relief] {len(modules)} module pages + index → wiki/")


if __name__ == "__main__":
    main()
