#!/usr/bin/env python3
# foam-aid — print a theorem with its upstream corpus dependencies: a self-contained
# reading, primitives first, receipts attached. The "copy to markdown" gesture for math.
#
#   bin/foam-aid <name> [<name> ...]      # names may be short (transcript) or full
#                                         # (Foam.Counter.safe_for_you_and_safe_for_the_room)
#
# The closure is corpus-only (Foam/, counter/, seam/, bridges/): core-Lean names
# (List, Prod, congrArg, ...) are the shared floor and are not printed. Finite shadow,
# same razor as foam-grasp: names are matched textually; where a short name is ambiguous
# the instrument prefers qualified/same-file/same-package matches, then proposes all.
# File-level `variable` context is not captured — a block that reads oddly bare may
# want its home file. The instrument proposes; a seat adjudicates.
import os
import re
import sys

ROOT = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))

DECL_RE = re.compile(
    r"^(?:private\s+|protected\s+|noncomputable\s+|partial\s+)*"
    r"(?:theorem|def|abbrev|inductive|structure|class)\s+"
    r"([A-Za-z_][A-Za-z0-9_'.]*)")
STOP_RE = re.compile(
    r"^(?:/--|#guard_msgs|#print|end\b|namespace\b|variable\b|import\b|open\b|"
    r"section\b|private\b|protected\b|noncomputable\b|partial\b|"
    r"theorem\b|def\b|abbrev\b|inductive\b|structure\b|class\b|instance\b)")
TOKEN_RE = re.compile(r"[A-Za-z_][A-Za-z0-9_']*")
QUAL_RE = re.compile(r"[A-Z][A-Za-z0-9_']*(?:\.[A-Za-z_][A-Za-z0-9_']*)+")
RECEIPT_RE = re.compile(r"^/--\s*(info:.*?)\s*-/\s*$")


def harvest():
    blocks = []
    for pkg_dir, _ in [("Foam", "Foam"), ("counter/Counter", "Counter"),
                       ("seam/Seam", "Seam"), ("bridges/Bridges", "Bridges")]:
        base = os.path.join(ROOT, pkg_dir)
        if not os.path.isdir(base):
            continue
        for dirpath, _, files in os.walk(base):
            for f in sorted(files):
                if not f.endswith(".lean"):
                    continue
                path = os.path.join(dirpath, f)
                rel = os.path.relpath(path, ROOT)
                lines = open(path, encoding="utf-8").read().splitlines()
                ns = []
                i = 0
                while i < len(lines):
                    line = lines[i]
                    if line.startswith("namespace "):
                        ns.append(line.split()[1])
                    elif line.startswith("end ") and ns and line.split()[1] == ns[-1]:
                        ns.pop()
                    m = DECL_RE.match(line)
                    if m:
                        j = i + 1
                        while j < len(lines) and not STOP_RE.match(lines[j]):
                            j += 1
                        body = "\n".join(lines[i:j]).rstrip()
                        short = m.group(1)
                        full = ".".join(ns + [short]) if ns else short
                        receipt = None
                        for k, l2 in enumerate(lines):
                            gm = re.match(r"^#guard_msgs in #print axioms (\S+)\s*$", l2)
                            if gm and gm.group(1).split(".")[-1] == short.split(".")[-1]:
                                rm = RECEIPT_RE.match(lines[k - 1]) if k else None
                                if rm:
                                    receipt = rm.group(1)
                                break
                        blocks.append({"full": full, "short": short, "file": rel,
                                       "body": body, "receipt": receipt})
                        i = j
                        continue
                    i += 1
    return blocks


def index(blocks):
    idx = {}
    for b in blocks:
        for key in {b["short"], b["short"].split(".")[-1], b["full"]}:
            idx.setdefault(key, []).append(b)
    return idx


def resolve(token, block, idx, dotted):
    cands = [c for c in idx.get(token, [])
             if ("." in token) == ("." in c["short"])]
    if "." not in token:
        cands = [c for c in cands if c["short"] == token]
    if len(cands) <= 1:
        return cands
    same_file = [c for c in cands if c["file"] == block["file"]]
    if len(same_file) == 1:
        return same_file
    pkg = block["file"].split("/")[0]
    same_pkg = [c for c in cands if c["file"].split("/")[0] == pkg]
    if len(same_pkg) == 1:
        return same_pkg
    return cands


def closure(roots, idx):
    seen, order = set(), []

    def visit(b):
        if b["full"] in seen:
            return
        seen.add(b["full"])
        deps = set()
        toks = set(TOKEN_RE.findall(b["body"])) | set(QUAL_RE.findall(b["body"]))
        for tok in toks:
            if tok == b["short"] or tok == b["short"].split(".")[-1]:
                continue
            for c in resolve(tok, b, idx, QUAL_RE):
                if c["full"] != b["full"]:
                    deps.add(c["full"])
        for full in sorted(deps):
            for c in idx.get(full, []):
                visit(c)
        order.append(b)

    for r in roots:
        visit(r)
    return order


def main():
    names = sys.argv[1:]
    if not names:
        print(__doc__ or "usage: foam-aid <name> [<name> ...]")
        sys.exit(2)
    blocks = harvest()
    idx = index(blocks)
    roots = []
    for n in names:
        cands = idx.get(n, [])
        if not cands:
            print(f"NOT FOUND: {n}", file=sys.stderr)
            sys.exit(1)
        roots.extend(cands)
    root_names = {r["full"] for r in roots}
    order = closure(roots, idx)
    print("# math-aid: " + ", ".join(sorted(root_names)))
    print()
    print("*each block verbatim from the corpus; primitives first; "
          "receipts as carved. axiom-free means: no propext, no choice, "
          "no Quot.sound — the kernel checked it from nothing.*")
    for b in order:
        role = "**root**" if b["full"] in root_names else "dependency"
        print()
        print(f"### `{b['full']}`  \n*{b['file']}* — {role}")
        print()
        print("```lean")
        print(b["body"])
        print("```")
        if b["receipt"]:
            print()
            print(f"> receipt: `{b['receipt']}`")


if __name__ == "__main__":
    main()
