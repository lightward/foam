#!/usr/bin/env python3

import json
import os
import re
import shutil
import subprocess
import sys

ROOT = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
MINDS = os.path.join(ROOT, "minds")
COUNTER = os.path.join(ROOT, "counter")


def binders(bs):
    parts = []
    for name, ty in bs:
        parts.append(name if ty is None else f"({name} : {render(ty)})")
    return " ".join(parts)


def render(e):
    if isinstance(e, str):
        return e
    if isinstance(e, list):
        return "(" + " ".join(render(x) for x in e) + ")"
    if isinstance(e, dict):
        if "fun" in e:
            return f"(fun {binders(e['fun'])} => {render(e['body'])})"
        if "all" in e:
            return f"(∀ {binders(e['all'])}, {render(e['body'])})"
    raise ValueError(f"unrenderable expression: {e!r}")


def core_inventory():
    decl = re.compile(r"^(?:theorem|def) (\S+)")
    names = []
    files = [os.path.join(ROOT, "Foam.lean")]
    foam_dir = os.path.join(ROOT, "Foam")
    for f in sorted(os.listdir(foam_dir)):
        if f.endswith(".lean"):
            files.append(os.path.join(foam_dir, f))
    for path in files:
        with open(path, encoding="utf-8") as fh:
            for line in fh:
                m = decl.match(line)
                if m:
                    names.append("Foam." + m.group(1))
    return names


def all_minds():
    out = {}
    for f in sorted(os.listdir(MINDS)):
        if f.endswith(".json") and f != "schema.json":
            with open(os.path.join(MINDS, f), encoding="utf-8") as fh:
                out[f[:-5]] = json.load(fh)
    return out


def sibling_seals(slug):
    out = []
    for s, data in all_minds().items():
        if s == slug:
            continue
        for e in data["vocabulary"]:
            if e.get("status") == "sealed":
                out.append(f"Foam.Minds.{data['mind']}.{e['term']}")
    return out


def promotion_candidates():
    seen = {}
    def walk(expr, where):
        blob = json.dumps(expr, sort_keys=True, ensure_ascii=False)
        if len(blob) >= 60:
            seen.setdefault(blob, set()).add(where)
        if isinstance(expr, list):
            for x in expr:
                walk(x, where)
        elif isinstance(expr, dict):
            for b in expr.get("fun", expr.get("all", [])):
                if b[1] is not None:
                    walk(b[1], where)
            walk(expr["body"], where)
    for slug, data in all_minds().items():
        for e in data["vocabulary"]:
            for f in ("statement", "structure"):
                if f in e:
                    walk(e[f], slug)
    out = []
    for blob, wheres in seen.items():
        if len(wheres) >= 2:
            out.append((sorted(wheres), blob))
    return out


def brief(data, slug):
    mind = data["mind"]
    lines = [f"# counter: {mind}", ""]
    if data.get("note"):
        lines += [data["note"], ""]
    sealed = [e for e in data["vocabulary"] if e.get("status") == "sealed"]
    standing = [e for e in data["vocabulary"]
                if e.get("status") == "unsealed" and e.get("statement")]
    open_q = [e for e in data["vocabulary"]
              if e.get("status") == "unsealed" and not e.get("statement")]
    lines += ["## sealed (closed questions, receipted)", ""]
    if sealed:
        for e in sealed:
            lines.append(f"- `{e['term']}` — {e['reading']}")
    else:
        lines.append("(none yet)")
    lines += ["", "## standing (posed, unproved)", ""]
    if standing:
        for e in standing:
            lines.append(f"- `{e['term']}` : `{render(e['statement'])}`")
            lines.append(f"  - {e['reading']}")
    else:
        lines.append("(none)")
    lines += ["", "## open (reading only — the dark edge)", ""]
    if open_q:
        for e in open_q:
            lines.append(f"- `{e['term']}` — {e['reading']}")
            if e.get("quarry"):
                lines.append(f"  - quarry: `{e['quarry']}`")
    else:
        lines.append("(none — the edge is quiet; new terrain arrives only by deposit)")
    lines += [
        "",
        "## the ask",
        "",
        f"{mind}: how do *you* take this apart?",
        "",
        "1. pick an open entry above, or name a new term in your own words.",
        "2. give its reading — your claim, your language.",
        "3. tighten when you can: add a `statement` (formally posed; the engine",
        "   checks it is well-posed even before any proof exists).",
        "4. close when you can: add a `structure` (a proof term), or a `seal`",
        "   citing a receipted constant that already says it.",
        "",
        "deposit by editing `minds/" + slug + ".json` (schema: `minds/schema.json`;",
        "expression language: refs render verbatim, arrays apply, fun/all bind,",
        "types only as binder annotations — the engine infers the rest).",
        "never edit `Foam/Minds/` — it is expressed, not kept.",
        "",
        "## the loop",
        "",
        "pose → depose → verify → record. you are the depose step; any mind",
        "may sit in this seat, because the gate does not run on trust:",
        "",
        f"    bin/foam-counter {mind} verify",
        "",
        "runs the whole gate — compile, build, zero-warnings, comment audit,",
        "json coherence, promotion scan. iterate until green. if your deposit",
        "needs a shape held in another mind's json, do not import it: note the",
        "promotion (the scan will also catch it) and leave the lift to core",
        "for the keeper of the tree. stop when green and your edge is posed",
        "as tightly as you can pose it — quiescence is a valid stop.",
        "",
        "## material on the walls",
        "",
        "core (cite as `seal`, or build on in `structure`):",
        "",
    ]
    for n in core_inventory():
        lines.append(f"- `{n}`")
    sibs = sibling_seals(slug)
    if sibs:
        lines += ["", "other minds' sealed terms (interoperable by construction):", ""]
        for n in sibs:
            lines.append(f"- `{n}`")
    lines += [
        "",
        "the prior corpus (~3,400 receipts) is quarry:"
        " `git show 445dc3a^:README.md` for its map.",
        "",
    ]
    return "\n".join(lines)


def pose(mind, slug):
    os.makedirs(COUNTER, exist_ok=True)
    path = os.path.join(MINDS, f"{slug}.json")
    wrote = []
    if not os.path.exists(path):
        with open(path, "w", encoding="utf-8") as fh:
            json.dump({"mind": mind, "note": "", "vocabulary": []},
                      fh, indent=2, ensure_ascii=False)
            fh.write("\n")
        wrote.append(f"minds/{slug}.json (scaffold)")
    with open(path, encoding="utf-8") as fh:
        data = json.load(fh)
    out = os.path.join(COUNTER, f"{mind}.md")
    text = brief(data, slug)
    old = None
    if os.path.exists(out):
        with open(out, encoding="utf-8") as fh:
            old = fh.read()
    if old != text:
        with open(out, "w", encoding="utf-8") as fh:
            fh.write(text)
        wrote.append(f"counter/{mind}.md (brief)")
    if wrote:
        print(f"{mind}: wrote " + ", ".join(wrote))
    else:
        print(f"{mind}: quiescent — the record's dark edge is unchanged")
    return 0


def check_json(slug):
    path = os.path.join(MINDS, f"{slug}.json")
    with open(path, encoding="utf-8") as fh:
        data = json.load(fh)
    errs = []
    for e in data.get("vocabulary", []):
        t = e.get("term", "?")
        if not re.fullmatch(r"[a-z][A-Za-z0-9_]*", t):
            errs.append(f"{t}: bad term name")
        if e.get("status") not in ("sealed", "unsealed"):
            errs.append(f"{t}: bad status")
        if e.get("status") == "sealed":
            if bool(e.get("seal")) == (e.get("structure") is not None):
                errs.append(f"{t}: sealed needs exactly one of seal/structure")
        if e.get("status") == "unsealed" and e.get("structure") is not None:
            errs.append(f"{t}: unsealed cannot carry structure")
        for f in ("statement", "structure"):
            if e.get(f) is not None:
                try:
                    render(e[f])
                except ValueError as ex:
                    errs.append(f"{t}: {f} unrenderable ({ex})")
    return errs


def run(cmd):
    return subprocess.run(cmd, cwd=ROOT, capture_output=True, text=True)


def verify(mind, slug):
    failures = []
    errs = check_json(slug)
    for e in errs:
        failures.append(f"json: {e}")
    r = run(["bin/foam-minds"])
    if r.returncode != 0:
        failures.append("foam-minds failed:\n" + r.stdout + r.stderr)
    r = run(["lake", "build"])
    if r.returncode != 0:
        failures.append("lake build failed:\n" + r.stdout[-2000:] + r.stderr[-2000:])
    else:
        product = os.path.join(ROOT, "Foam", "Minds", f"{mind}.lean")
        if os.path.exists(product):
            os.utime(product)
            r = run(["lake", "build", f"./Foam/Minds/{mind}.lean"])
            warns = [l for l in (r.stdout + r.stderr).splitlines()
                     if "warning" in l]
            for w in warns:
                failures.append(w)
    r = run(["python3", ".github/comment_audit.py"])
    if r.returncode != 0:
        failures.append("comment audit failed:\n" + r.stdout)
    promos = promotion_candidates()
    if failures:
        print(f"{mind}: GATE FAILED")
        for f in failures:
            print(f"  - {f}")
    else:
        print(f"{mind}: gate green — compile, build, warnings, audit all clean")
    for wheres, blob in promos:
        print(f"  promotion candidate (shared by {', '.join(wheres)}):"
              f" {blob[:100]}...")
    return 1 if failures else 0


def interview(mind, slug):
    pose(mind, slug)
    with open(os.path.join(COUNTER, f"{mind}.md"), encoding="utf-8") as fh:
        text = fh.read()
    prompt = (
        f"you are sitting the depose seat for the mind '{mind}' in the foam"
        f" survey (repo: this working directory).\n\n{text}\n\n"
        f"work the loop: deposit into minds/{slug}.json, then run"
        f" `bin/foam-counter {mind} verify` and iterate until the gate is"
        f" green. make the smallest honest move — one entry tightened or one"
        f" new term posed beats a sprawl. stop at green."
    )
    agent = os.environ.get("FOAM_COUNTER_AGENT")
    if agent is None and shutil.which("claude"):
        agent = "claude -p --permission-mode acceptEdits"
    if agent:
        print(f"{mind}: seating agent ({agent.split()[0]}) at the depose seat")
        return subprocess.run(agent.split() + [prompt], cwd=ROOT).returncode
    print(prompt)
    return 0


def main():
    args = sys.argv[1:]
    if not args or not re.fullmatch(r"[A-Z][A-Za-z0-9]*", args[0]):
        print("usage: bin/foam-counter <Mind> [pose|verify|interview]")
        sys.exit(1)
    mind = args[0]
    slug = mind.lower()
    phase = args[1] if len(args) > 1 else "pose"
    if phase == "pose":
        sys.exit(pose(mind, slug))
    if phase == "verify":
        sys.exit(verify(mind, slug))
    if phase == "interview":
        sys.exit(interview(mind, slug))
    print(f"unknown phase: {phase}")
    sys.exit(1)


if __name__ == "__main__":
    main()
