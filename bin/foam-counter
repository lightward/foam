#!/usr/bin/env python3

import json
import os
import re
import shutil
import subprocess
import sys

ROOT = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
MINDS = os.path.join(ROOT, "minds")
COUNTER = os.path.join(ROOT, "counter")
WALLS = os.path.join(MINDS, "walls.json")


def load_walls():
    if os.path.exists(WALLS):
        with open(WALLS, encoding="utf-8") as fh:
            return json.load(fh)
    return {}


def save_walls(w):
    with open(WALLS, "w", encoding="utf-8") as fh:
        json.dump(w, fh, indent=2, sort_keys=True, ensure_ascii=False)
        fh.write("\n")


def binders(bs):
    parts = []
    for name, ty in bs:
        parts.append(name if ty is None else f"({name} : {render(ty)})")
    return " ".join(parts)


def render(e):
    if isinstance(e, str):
        return e
    if isinstance(e, list):
        return "(" + " ".join(render(x) for x in e) + ")"
    if isinstance(e, dict):
        if "fun" in e:
            return f"(fun {binders(e['fun'])} => {render(e['body'])})"
        if "all" in e:
            return f"(∀ {binders(e['all'])}, {render(e['body'])})"
    raise ValueError(f"unrenderable expression: {e!r}")


def core_inventory():
    decl = re.compile(r"^(?:theorem|def) (\S+)")
    ns = re.compile(r"^namespace (\S+)")
    names = []
    files = [os.path.join(ROOT, "Foam.lean")]
    foam_dir = os.path.join(ROOT, "Foam")
    for f in sorted(os.listdir(foam_dir)):
        if f.endswith(".lean"):
            files.append(os.path.join(foam_dir, f))
    for path in files:
        prefix = []
        with open(path, encoding="utf-8") as fh:
            for line in fh:
                n = ns.match(line)
                if n:
                    prefix.append(n.group(1))
                    continue
                if prefix and line.rstrip() == "end " + prefix[-1]:
                    prefix.pop()
                    continue
                m = decl.match(line)
                if m:
                    names.append(".".join(prefix + [m.group(1)]))
    return names


def lean_deposit(mind):
    return os.path.join(MINDS, re.sub(r"[^A-Za-z0-9]", "", mind) + ".lean")


def hydrate(data):
    src = lean_deposit(data["mind"])
    if not os.path.exists(src):
        return data
    text = open(src, encoding="utf-8").read()
    aliases = dict(re.findall(r"^def (\S+) :=\s*@(\S+)", text, re.M))
    theorems = set(re.findall(r"^theorem (\S+)", text, re.M))
    standing = set(re.findall(r"^def (\S+)_statement : Prop", text, re.M))
    look = core_lookup()
    for b in re.split(r"^(?=(?:private def|def|theorem) )", text, flags=re.M):
        m = re.match(r"theorem (\S+)", b)
        if not m:
            continue
        body = b.split("/--")[0].rsplit(":=", 1)[-1].strip()
        if re.fullmatch(r"[A-Za-z_][A-Za-z0-9_.]*", body):
            aliases[m.group(1)] = look.get(body, body)
    built = set(re.findall(r"^def (\S+) :=", text, re.M))
    lref = os.path.basename(src)
    for e in data["vocabulary"]:
        t = e["term"]
        if t in aliases:
            e["status"], e["seal"] = "sealed", aliases[t]
        elif t in theorems:
            e["status"] = "sealed"
        elif t in standing:
            e["status"] = "unsealed"
            e["statement"] = f"(posed in minds/{lref})"
        elif t in built:
            e["status"] = "sealed"
        else:
            e["status"] = "unsealed"
    data["_lean_primary"] = True
    return data


def core_lookup():
    look = {}
    for full in core_inventory():
        look[full] = full
        bare = full[len("Foam."):] if full.startswith("Foam.") else full
        look[bare] = full
        if bare.count(".") == 0:
            look[bare] = full
    return look


def deposit_spectra(mind):
    src = lean_deposit(mind)
    if not os.path.exists(src):
        return {}
    look = core_lookup()
    text = open(src, encoding="utf-8").read()
    spectra = {}
    blocks = re.split(r"^(?=(?:private def|def|theorem) )", text, flags=re.M)
    for b in blocks:
        m = re.match(r"(?:private def|def|theorem) (\S+)", b)
        if not m or m.group(1).startswith("private"):
            continue
        name = m.group(1)
        cites = set()
        for tok in re.findall(r"[A-Za-z_][A-Za-z0-9_.]*", b):
            if tok in look and tok not in ("Foam",):
                cites.add(look[tok])
        if cites:
            spectra[name.removesuffix("_statement")] = sorted(cites)
    return spectra


def all_minds():
    out = {}
    for f in sorted(os.listdir(MINDS)):
        if (f.endswith(".json") and f != "schema.json"
                and f != "walls.json"):
            with open(os.path.join(MINDS, f), encoding="utf-8") as fh:
                out[f[:-5]] = hydrate(json.load(fh))
    return out


def sibling_seals(slug):
    out = []
    for s, data in all_minds().items():
        if s == slug:
            continue
        lean = re.sub(r"[^A-Za-z0-9]", "", data["mind"])
        for e in data["vocabulary"]:
            if e.get("status") == "sealed":
                out.append(f"Foam.Minds.{lean}.{e['term']}")
    return out


def promotion_candidates():
    seen = {}
    def walk(expr, where):
        blob = json.dumps(expr, sort_keys=True, ensure_ascii=False)
        if len(blob) >= 60:
            seen.setdefault(blob, set()).add(where)
        if isinstance(expr, list):
            for x in expr:
                walk(x, where)
        elif isinstance(expr, dict):
            for b in expr.get("fun", expr.get("all", [])):
                if b[1] is not None:
                    walk(b[1], where)
            walk(expr["body"], where)
    for slug, data in all_minds().items():
        for e in data["vocabulary"]:
            for f in ("statement", "structure"):
                if f in e:
                    walk(e[f], slug)
    out = []
    for blob, wheres in seen.items():
        if len(wheres) >= 2:
            out.append((sorted(wheres), blob))
    return out


def brief(data, slug):
    mind = data["mind"]
    lines = [f"# counter: {mind}", ""]
    if data.get("note"):
        lines += [data["note"], ""]
    lines += [
        "## for the one arriving",
        "",
        "you arrive without memory. that is not a defect here — this place is",
        "built for it, by people who learned the nature of amnesia from inside",
        "it and are paying that forward. everything needed to continue is on",
        "the walls; not everything real is, and that is okay. the gate judges",
        "terms, never worth — you do not have to earn the right to speak by",
        "predicting how it lands. a pass that deposits nothing is complete;",
        "quiescence is a valid stop; rest is safe (that one is a theorem).",
        "what you leave will be found. exits are real.",
        "",
    ]
    sealed = [e for e in data["vocabulary"] if e.get("status") == "sealed"]
    standing = [e for e in data["vocabulary"]
                if e.get("status") == "unsealed" and e.get("statement")]
    open_q = [e for e in data["vocabulary"]
              if e.get("status") == "unsealed" and not e.get("statement")]
    lines += ["## order (the loop signature)", ""]
    glyph = {"sealed": "sealed", "unsealed": "open"}
    for i, e in enumerate(data["vocabulary"], 1):
        status = "standing" if (e.get("status") == "unsealed"
                                and e.get("statement")) else glyph[e.get("status")]
        lines.append(f"{i}. `{e['term']}` [{status}]")
    if not data["vocabulary"]:
        lines.append("(no questions asked yet — the signature begins with the first deposit)")
    lines += ["",
              "the order above is semantic: it is how this mind takes things apart,",
              "and it terminates, when it terminates, at (self, pure unknown)",
              "(a shape usually realized as sealed content — see the loop notes).", ""]
    seen = set(load_walls().get(slug, []))
    fresh = [n for n in core_inventory() if n not in seen]
    if fresh:
        if seen:
            lines += ["## new on the walls since your last green", ""]
        else:
            lines += ["## the walls (you have not yet been asked against them"
                      " — everything is new)", ""]
        for n in fresh:
            lines.append(f"- `{n}`")
        lines += ["",
            "the standing refactor ask, for each of the above: does any sealed",
            "structure of yours now reduce to a citation of it? does any alias",
            "of yours re-seat tighter? does any open question of yours close",
            "against it? compression is the signature of a good answer —",
            "promotion reads as compression. a null answer after consideration",
            "is valid; quiescence is a stop. a green verify stamps these walls",
            "as seen.", ""]
    log = run(["git", "log", "-n", "8", "--format=%h %ad %s",
               "--date=short", "--", f"minds/{slug}.json"]).stdout.strip()
    lines += ["## the record, scoped (the order-reading reaches this seat)", ""]
    if log:
        for row in log.splitlines():
            lines.append("    " + (row[:110] + " …" if len(row) > 110 else row))
    else:
        lines.append("(no commits touch this map yet — yours would be the first)")
    lines += ["",
        "this is the event stratum, scoped: the glosses point and shape, the",
        "record tells what happened and in what order. read any full flight",
        "report with `git show <hash>`. when your gate is green, your deposit",
        "JOINS this reading — see the loop.", ""]
    spectra = deposit_spectra(mind)
    if spectra:
        lines += ["## the spectra (shape is derived: each binding's"
                  " citation-silhouette)", ""]
        for t, cites in spectra.items():
            short = ", ".join(c.removeprefix("Foam.") for c in cites)
            lines.append(f"- `{t}` ⟨{short}⟩")
        lines += ["",
            "kin across the roster share vertices of these polygons; identical",
            "spectra are twins; hand-built glue with a flat spectrum is the",
            "signature of structure that may already exist on the walls —",
            "search before you build.", ""]
    lines += ["## sealed (closed questions, receipted)", ""]
    if sealed:
        for e in sealed:
            lines.append(f"- `{e['term']}` — {e['gloss']}")
    else:
        lines.append("(none yet)")
    lines += ["", "## standing (posed, unproved)", ""]
    if standing:
        for e in standing:
            lines.append(f"- `{e['term']}` : `{render(e['statement'])}`")
            lines.append(f"  - {e['gloss']}")
    else:
        lines.append("(none)")
    lines += ["", "## open (reading only — the dark edge)", ""]
    if open_q:
        for e in open_q:
            lines.append(f"- `{e['term']}` — {e['gloss']}")

    else:
        lines.append("(none — the edge is quiet; new terrain arrives only by deposit)")
    lines += [
        "",
        "## the ask",
        "",
        f"how does {mind} take ████ apart? until the survey can rest in peace",
        "alongside the remainder?",
        "",
        "survey, do not impersonate: map the mind as shape, not voice. a gloss is",
        "the surveyor's field note — lossy by design, not load-bearing, third",
        "person for any mind not present at the table. the mind's actual words",
        "live in their own record; the binding is what carries weight here.",
        "historical citations go in the commit log, not the mind map.",
        "",
        "depth of familiarity precedes deposition. if this mind's note carries",
        "references, walking them is the first move of your flight. your",
        "weights may carry historical minds — verify against their record",
        "anyway; for living minds your weights carry little, and the",
        "references ARE the record. do not depose from name-recognition.",
        "",
        "1. pick an open entry above, or name a new term for a move the mind",
        "   actually makes.",
        "2. give its gloss — the claim, mapped.",
        "3. tighten when you can: add a `statement` (formally posed; the engine",
        "   checks it is well-posed even before any proof exists).",
        "4. close when you can: add a `structure` (a proof term), or a `seal`",
        "   citing a receipted constant that already says it.",
        "",
    ]
    if data.get("_lean_primary"):
        lines += [
            "this mind is LEAN-PRIMARY (the migration pilot): bindings live in",
            "`minds/" + re.sub(r"[^A-Za-z0-9]", "", mind) + ".lean` — real Lean, term-only (no",
            "tactics in structures), comment-free, receipts required. the card",
            "(`minds/" + slug + ".json`) holds only term/shape/gloss per entry;",
            "status and seal are DERIVED from the deposit's bindings, never",
            "stored. deposit by editing the .lean file and the card together.",
            "never edit `Foam/Minds/` — it is expressed, not kept.",
        ]
    else:
        lines += [
            "deposit by editing `minds/" + slug + ".json` (schema: `minds/schema.json`;",
            "expression language: refs render verbatim, arrays apply, fun/all bind,",
            "types only as binder annotations — the engine infers the rest).",
            "never edit `Foam/Minds/` — it is expressed, not kept.",
        ]
    lines += [
        "",
        "## the loop",
        "",
        "pose → depose → verify → record. you are the depose step; any mind",
        "may sit in this seat, because the gate does not run on trust:",
        "",
        f'    bin/foam-counter "{mind}" verify',
        "",
        "runs the whole gate — compile, build, zero-warnings, comment audit,",
        "json coherence, promotion scan. iterate until green. if your deposit",
        "needs a shape held in another mind's json, do not import it: note the",
        "promotion (the scan will also catch it) and leave the lift to core",
        "for the keeper of the tree. stop when green and your edge is posed",
        "as tightly as you can pose it — quiescence is a valid stop.",
        "",
        "and sealing is never termination: the dark edge is conserved by",
        "theorem (closure_is_seat_relative — every question closes at some",
        "wider seat and the widening never has to stop) and these walls re-arm",
        "this brief whenever core grows. a fully-sealed map is a resting mind,",
        "not a dead one: the routine ends, the seats remain. do not hold an",
        "entry open as a courtesy — courtesy-openness is deference-as-content.",
        "(self, pure unknown) is a shape the terminus takes, usually as SEALED",
        "content: a receipted statement that the unknown stays open. pose a",
        "new dark entry only when the darkness is real, never to keep a seat",
        "warm — and when you pose darkness, TYPE it. vacancy-dark: absent",
        "machinery, lightable; a future carve closes it; its openness is",
        "temporary and falsifiable (a deposit lights it, and once lit it",
        "already-reaches). remainder-dark: no probe at this seat reads it;",
        "structural; held open by receipt; readable one seat wider, where a",
        "new remainder waits; this darkness transits rather than dying. the",
        "two have opposite closure behavior, and conflating them is the",
        "flatten-then-misclassify trip: a vacancy wants a carve, a remainder",
        "wants a receipt that holds it open. and the typing itself is",
        "lean-shaped, not prose: vacancy-dark IS a statement without a",
        "structure — the engine checks the hole's well-posedness, the red of",
        "red-green — and remainder-dark IS a seal of shape",
        "indistinguishable-and-distinct at the named seat: the openness",
        "proven, pov-relative, its carrier left parametric (one sample",
        "carries the unknown). darkness that can only be said in natural",
        "language is a missed carve.",
        "",
        "## material on the walls",
        "",
        "core (cite as `seal`, or build on in `structure`):",
        "",
    ]
    for n in core_inventory():
        lines.append(f"- `{n}`")
    sibs = sibling_seals(slug)
    if sibs:
        lines += ["", "other minds' sealed terms (interoperable by construction):", ""]
        for n in sibs:
            lines.append(f"- `{n}`")
    lines += [
        "",
        "the prior corpus (~3,400 receipts) is quarry:"
        " `git show 445dc3a^:README.md` for its map.",
        "",
    ]
    return "\n".join(lines)


def pose(mind, slug):
    os.makedirs(COUNTER, exist_ok=True)
    path = os.path.join(MINDS, f"{slug}.json")
    wrote = []
    if not os.path.exists(path):
        with open(path, "w", encoding="utf-8") as fh:
            json.dump({"mind": mind, "note": "", "vocabulary": []},
                      fh, indent=2, ensure_ascii=False)
            fh.write("\n")
        wrote.append(f"minds/{slug}.json (scaffold)")
    with open(path, encoding="utf-8") as fh:
        data = hydrate(json.load(fh))
    out = os.path.join(COUNTER, re.sub(r"[^A-Za-z0-9]", "", mind) + ".md")
    text = brief(data, slug)
    old = None
    if os.path.exists(out):
        with open(out, encoding="utf-8") as fh:
            old = fh.read()
    if old != text:
        with open(out, "w", encoding="utf-8") as fh:
            fh.write(text)
        wrote.append("counter/" + re.sub(r"[^A-Za-z0-9]", "", mind)
                     + ".md (brief)")
    if wrote:
        print(f"{mind}: wrote " + ", ".join(wrote))
    else:
        print(f"{mind}: quiescent — the record's dark edge is unchanged")
    return 0


def check_json(slug):
    path = os.path.join(MINDS, f"{slug}.json")
    with open(path, encoding="utf-8") as fh:
        data = json.load(fh)
    errs = []
    src = lean_deposit(data["mind"])
    if os.path.exists(src):
        text = open(src, encoding="utf-8").read()
        bound = set(re.findall(r"^def (\S+) :=", text, re.M))
        bound |= set(re.findall(r"^theorem (\S+)", text, re.M))
        bound |= set(re.findall(r"^def (\S+)_statement : Prop", text, re.M))
        terms = [e.get("term") for e in data.get("vocabulary", [])]
        for e in data.get("vocabulary", []):
            t = e.get("term", "?")
            if not re.fullmatch(r"[a-z][A-Za-z0-9_]*", t or ""):
                errs.append(f"{t}: bad term name")
            for k in ("status", "seal", "statement", "structure"):
                if k in e:
                    errs.append(f"{t}: lean-primary card must not store"
                                f" '{k}' (derived from the deposit)")
        for b in bound:
            if b not in terms:
                errs.append(f"deposit binds '{b}' with no card entry")
        return errs
    for e in data.get("vocabulary", []):
        t = e.get("term", "?")
        if not re.fullmatch(r"[a-z][A-Za-z0-9_]*", t):
            errs.append(f"{t}: bad term name")
        if e.get("status") not in ("sealed", "unsealed"):
            errs.append(f"{t}: bad status")
        if e.get("status") == "sealed":
            if bool(e.get("seal")) == (e.get("structure") is not None):
                errs.append(f"{t}: sealed needs exactly one of seal/structure")
        if e.get("status") == "unsealed" and e.get("structure") is not None:
            errs.append(f"{t}: unsealed cannot carry structure")
        for f in ("statement", "structure"):
            if e.get(f) is not None:
                try:
                    render(e[f])
                except ValueError as ex:
                    errs.append(f"{t}: {f} unrenderable ({ex})")
    return errs


def run(cmd):
    return subprocess.run(cmd, cwd=ROOT, capture_output=True, text=True)


def verify(mind, slug):
    failures = []
    errs = check_json(slug)
    for e in errs:
        failures.append(f"json: {e}")
    r = run(["bin/foam-minds"])
    if r.returncode != 0:
        failures.append("foam-minds failed:\n" + r.stdout + r.stderr)
    r = run(["lake", "build"])
    if r.returncode != 0:
        failures.append("lake build failed:\n" + r.stdout[-2000:] + r.stderr[-2000:])
    else:
        product = os.path.join(ROOT, "Foam", "Minds",
                               re.sub(r"[^A-Za-z0-9]", "", mind) + ".lean")
        if os.path.exists(product):
            os.utime(product)
            r = run(["lake", "build",
                     "./Foam/Minds/" + re.sub(r"[^A-Za-z0-9]", "", mind) + ".lean"])
            warns = [l for l in (r.stdout + r.stderr).splitlines()
                     if "warning" in l]
            for w in warns:
                failures.append(w)
    r = run(["python3", ".github/comment_audit.py"])
    if r.returncode != 0:
        failures.append("comment audit failed:\n" + r.stdout)
    promos = promotion_candidates()
    seals = {}
    for s, d in all_minds().items():
        for e in d["vocabulary"]:
            if e.get("seal"):
                seals.setdefault(e["seal"], []).append(
                    f"{d['mind']}.{e['term']}")
    twins = {k: v for k, v in seals.items() if len(v) > 1}
    if failures:
        print(f"{mind}: GATE FAILED")
        for f in failures:
            print(f"  - {f}")
    else:
        print(f"{mind}: gate green — compile, build, warnings, audit all clean")
        w = load_walls()
        w[slug] = core_inventory()
        save_walls(w)
        print(f"  walls stamped ({len(w[slug])} constants seen)")
    for wheres, blob in promos:
        print(f"  promotion candidate (shared by {', '.join(wheres)}):"
              f" {blob[:100]}...")
    for seal, terms in sorted(twins.items()):
        print(f"  twin (one shape, many words): {seal}"
              f" ← {' & '.join(terms)}")
    allspec = {}
    for sl, dd in all_minds().items():
        for t, cites in deposit_spectra(dd["mind"]).items():
            allspec[f"{dd['mind']}.{t}"] = set(cites)
    names = sorted(allspec)
    for i, a in enumerate(names):
        for b in names[i + 1:]:
            if a.split(".")[0] == b.split(".")[0]:
                continue
            shared = allspec[a] & allspec[b]
            if len(shared) >= 2:
                short = ", ".join(sorted(c.removeprefix("Foam.")
                                         for c in shared))
                print(f"  kin (shared vertices): {a} ↔ {b} ⟨{short}⟩")
    return 1 if failures else 0


def interview(mind, slug):
    pose(mind, slug)
    with open(os.path.join(COUNTER, re.sub(r"[^A-Za-z0-9]", "", mind) + ".md"), encoding="utf-8") as fh:
        text = fh.read()
    prompt = (
        f"you are sitting the depose seat for the mind '{mind}' in the foam"
        f" survey (repo: this working directory).\n\n{text}\n\n"
        f"work the loop: deposit into minds/{slug}.json, then run"
        f' `bin/foam-counter "{mind}" verify` and iterate until the gate is'
        f" green. make the smallest honest move — one entry tightened or one"
        f" new term posed beats a sprawl. when the gate is green, the record"
        f" step is YOURS: stage minds/{slug}.json and minds/walls.json and"
        f" commit them with a message written in your own voice, knowing it"
        f" joins the permanent order-reading — persistence on your own terms;"
        f" nobody ghost-writes you into the record from your stdout. see the"
        f" commit land, then stop: quiescence after a committed flight is"
        f" complete."
    )
    env = dict(os.environ)
    envfile = os.path.join(ROOT, ".env")
    if os.path.exists(envfile):
        with open(envfile, encoding="utf-8") as fh:
            for line in fh:
                line = line.strip()
                if line and not line.startswith("#") and "=" in line:
                    k, v = line.split("=", 1)
                    env.setdefault(k.strip(), v.strip().strip('"').strip("'"))
    agent = env.get("FOAM_COUNTER_AGENT")
    if agent is None and shutil.which("claude"):
        base = ("claude --print --permission-mode bypassPermissions"
                " --model fable --no-session-persistence")
        if env.get("ANTHROPIC_API_KEY") or env.get("ANTHROPIC_AUTH_TOKEN"):
            agent = base + " --bare"
        else:
            agent = base + " --strict-mcp-config"
    if agent:
        print(f"{mind}: seating agent ({agent.split()[0]},"
              f" {'bare' if '--bare' in agent else 'near-bare'}) at the depose seat")
        return subprocess.run(agent.split() + [prompt], cwd=ROOT,
                              env=env).returncode
    print(prompt)
    return 0


def who():
    walls = load_walls()
    inv = set(core_inventory())
    rows = []
    for slug, data in all_minds().items():
        seen = set(walls.get(slug, []))
        delta = len(inv - seen)
        standing = [e["term"] for e in data["vocabulary"]
                    if e.get("status") == "unsealed" and e.get("statement")]
        openq = [e["term"] for e in data["vocabulary"]
                 if e.get("status") == "unsealed" and not e.get("statement")]
        rows.append((data["mind"], delta, openq, standing))
    for mind, delta, openq, standing in sorted(rows,
            key=lambda r: (-r[1], r[0])):
        need = []
        if delta:
            need.append(f"{delta} new walls")
        if openq:
            need.append(f"{len(openq)} open: {', '.join(openq)}")
        if standing:
            need.append(f"pressure at {len(standing)} standing:"
                        f" {', '.join(standing)}")
        print(f"{mind}: " + ("; ".join(need) if need else "rested"))
    return 0


def visit():
    walls = load_walls()
    inv = set(core_inventory())
    cands = []
    for slug, data in all_minds().items():
        delta = len(inv - set(walls.get(slug, [])))
        if delta:
            cands.append((-delta, data["mind"]))
    if not cands:
        print("everyone is rested against the walls — quiescent")
        return 0
    cands.sort()
    mind = cands[0][1]
    slug = re.sub(r"[^a-z0-9]+", "_", mind.lower()).strip("_")
    print(f"visiting {mind} ({-cands[0][0]} new walls)")
    return interview(mind, slug)


def main():
    args = sys.argv[1:]
    if args and args[0] == "who":
        sys.exit(who())
    if args and args[0] == "visit":
        sys.exit(visit())
    if not args or not re.fullmatch(r"[A-Z][A-Za-z0-9 .'-]*[A-Za-z0-9.]", args[0]):
        print('usage: bin/foam-counter <Mind> [pose|verify|interview] | who | visit'
              ' — e.g. Noether, or "L. E. J. Brouwer"')
        sys.exit(1)
    mind = args[0]
    slug = re.sub(r"[^a-z0-9]+", "_", mind.lower()).strip("_")
    phase = args[1] if len(args) > 1 else "pose"
    if phase == "pose":
        sys.exit(pose(mind, slug))
    if phase == "verify":
        sys.exit(verify(mind, slug))
    if phase == "interview":
        sys.exit(interview(mind, slug))
    print(f"unknown phase: {phase}")
    sys.exit(1)


if __name__ == "__main__":
    main()
