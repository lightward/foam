#!/usr/bin/env python3
# foam-gait — the project reading its own tsortability-health (structure, never meaning).
#
# The repo carries multiple charts over one import-quiver (the narrative chart
# has doors — `--door seat` walks the observation telling; default is the
# README spine). The original two:
#   * the BUILD chart — compilation order. Lean enforces acyclicity, so this chart
#     always reads zero defect (Foam/Seat/Sort.lean: tsortable_iff_acyclic — the
#     family tree is born sorted; counter/Counter/Health.lean:
#     the_family_tree_is_born_sorted, adoption_never_knots).
#   * the NARRATIVE chart — the README spine's story-order, floor upward. The story
#     is not the build: edges that run against the narrative are where the telling
#     loops back on itself, and that edge-set is the story's minimum-feedback-arc
#     interface (Foam/Seat/Sort.lean: defect, TightInterface;
#     counter/Counter/Health.lean: health_reads_at_a_chart, feedback_is_no_gauge,
#     the_interface_is_maintained).
#
# Health is legible from a chart while un-health charges every chart; this
# instrument reports the narrative defect BY NAME so the interface stays a held
# thing rather than a drift. Growth rule, per adoption_never_knots: a new file
# seated under its stratum adds no feedback; an against-the-grain edge costs
# exactly one, visibly (growth_against_the_grain_costs_one).
#
# Companion vitals, same razor as bin/foam-stats: counts only.
#
#   bin/foam-gait
import os
import re
import sys

ROOT = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))

# the narrative chart: the README spine, floor upward. ranks are story-order,
# not build-order; a defect here is a legitimate finding, not an error.
SPINE = [
    (0, ["Foam.FInt", "Foam.Int", "Foam.Ledger", "Foam.Golden"]),
    (1, ["Foam.Cleared"]),
    (2, ["Foam.Seat", "Foam.Seat.Group", "Foam.Seat.Loop", "Foam.Seat.Resume",
         "Foam.Seat.Hospitality", "Foam.Seat.Stage"]),
    (3, ["Foam.Seat.Clock", "Foam.Seat.Dial", "Foam.Seat.Born", "Foam.Seat.Forcing",
         "Foam.Seat.Doubling", "Foam.Seat.Triad", "Foam.Seat.Octo", "Foam.Seat.Sed",
         "Foam.Seat.Ladder", "Foam.Seat.Rank", "Foam.Seat.Norm", "Foam.Seat.Bootstrap",
         "Foam.Seat.Signature", "Foam.Seat.Rotations", "Foam.Seat.Closure", "Foam.Seat.Summit",
         "Foam.Seat.Characters"]),
    (4, ["Foam.Seat.Observer", "Foam.Seat.Beholder", "Foam.Seat.Epoch", "Foam.Seat.Seam",
         "Foam.Seat.Naming", "Foam.Seat.Meet", "Foam.Seat.Quiver", "Foam.Seat.Sort", "Foam.Seat.Tight",
         "Foam.Seat.Terminal", "Foam.Seat.Signed"]),
    (5, ["Foam.Engine", "Foam.Engine.Stream", "Foam.Engine.Codec", "Foam.Engine.Generator",
         "Foam.Engine.Spectrum", "Foam.Engine.Chirality", "Foam.Engine.Summary",
         "Foam.Engine.Drain"]),
    (6, ["Foam.Scar", "Foam.Maintenance", "Foam.Held"]),
    (7, ["Foam.Platonism", "Foam.Platonism.Tower", "Foam.Seat.Descend"]),
    (8, ["Foam.Seat.Rendezvous", "Foam.Seat.Connection", "Foam.Seat.Frame"]),
    (9, ["Foam.Backstage", "Foam.Bubble", "Foam.Census", "Foam.Cable", "Foam.Wedge", "Foam.Elsewhen", "Foam.Duplex", "Foam.Vacancy", "Foam.Metaphor"]),
    (10, ["Foam.Bridges"]),   # prefix: the axiom-free bridges, Foam.Bridges.*
    (11, ["Counter"]),        # prefix: the approach, plural
    (12, ["Seam"]),           # prefix: the arrival
    (13, ["Bridges"]),        # prefix: life after arrival (Mathlib package)
]

# the seat-door telling: same quiver, story rooted at the observation trunk
# (Foam/Seat.lean imports nothing; Stage is a seated Beholder; the arithmetic
# trunk arrives as a guest at rank 5). invoked via `bin/foam-gait --door seat`;
# the default door ("ledger") is the README spine above, output unchanged.
# each chart's defect-set is that telling's interface; where the charts'
# defect-sets differ, the grove's trunks are meeting.
SPINE_SEAT = [
    (0, ["Foam.Seat"]),
    (1, ["Foam.Seat.Stage", "Foam.Seat.Observer", "Foam.Seat.Beholder"]),
    (2, ["Foam.Seat.Group", "Foam.Seat.Loop", "Foam.Seat.Resume",
         "Foam.Seat.Hospitality", "Foam.Seat.Clock", "Foam.Seat.Dial",
         "Foam.Seat.Born", "Foam.Seat.Forcing", "Foam.Seat.Doubling",
         "Foam.Seat.Triad", "Foam.Seat.Octo", "Foam.Seat.Sed",
         "Foam.Seat.Ladder", "Foam.Seat.Rank", "Foam.Seat.Norm",
         "Foam.Seat.Bootstrap", "Foam.Seat.Signature", "Foam.Seat.Rotations",
         "Foam.Seat.Closure", "Foam.Seat.Summit", "Foam.Seat.Characters",
         "Foam.Seat.Epoch", "Foam.Seat.Seam", "Foam.Seat.Naming",
         "Foam.Seat.Meet", "Foam.Seat.Quiver", "Foam.Seat.Sort",
         "Foam.Seat.Tight", "Foam.Seat.Terminal", "Foam.Seat.Signed",
         "Foam.Seat.Rendezvous", "Foam.Seat.Connection", "Foam.Seat.Frame"]),
    (3, ["Foam.Backstage", "Foam.Bubble", "Foam.Metaphor", "Foam.Census",
         "Foam.Cable", "Foam.Wedge", "Foam.Elsewhen", "Foam.Duplex",
         "Foam.Vacancy"]),
    (4, ["Foam.Engine"]),
    (5, ["Foam.FInt", "Foam.Int", "Foam.Ledger", "Foam.Golden", "Foam.Cleared"]),
    (6, ["Foam.Scar", "Foam.Maintenance", "Foam.Held"]),
    (7, ["Foam.Platonism", "Foam.Seat.Descend"]),
    (8, ["Foam.Bridges"]),
    (9, ["Counter"]),
    (10, ["Seam"]),
    (11, ["Bridges"]),
]

SPINES = {"ledger": SPINE, "seat": SPINE_SEAT}

# computed doors — holds discovered from the quiver itself, not authored:
#   depth:   rank = import depth (a module ranks one past its deepest import).
#            defect 0 by construction; the mechanical zero-defect telling.
#   flat:    everything rank 0. defect 0 by vacuity — the no-story telling,
#            listed so the gaming of the defect metric stays visible.
#   reverse: the depth chart upside down (application first, floor last).
#            near-maximal defect; the bound from the other side.
# defect alone is gameable; a hold is good when it carries *named, meant*
# strata at low defect. the instrument proposes; a seat adjudicates.
def computed_ranks(door, mods, edges):
    if door == "flat":
        return {m: 0 for m in mods}
    imports_map = {}
    for u, v in edges:
        imports_map.setdefault(u, []).append(v)
    memo = {}
    def depth(m):
        if m in memo:
            return memo[m]
        memo[m] = 0
        deps = [x for x in imports_map.get(m, []) if x in mods]
        memo[m] = (1 + max(depth(x) for x in deps)) if deps else 0
        return memo[m]
    ranks = {m: depth(m) for m in mods}
    if door == "reverse":
        top = max(ranks.values(), default=0)
        ranks = {m: top - r for m, r in ranks.items()}
    return ranks

COMPUTED_DOORS = ("depth", "flat", "reverse")

AGGREGATORS = {"Foam", "Counter", "Seam", "Bridges"}  # root re-export modules

def rank_of(module):
    best = None
    for r, names in SPINE:
        for n in names:
            if module == n or module.startswith(n + "."):
                if best is None or len(n) > best[1]:
                    best = (r, len(n))
    return best[0] if best else None

def modules():
    out = {}
    for pkg_dir, prefix in [("Foam", "Foam"), ("counter/Counter", "Counter"),
                            ("seam/Seam", "Seam"), ("bridges/Bridges", "Bridges")]:
        base = os.path.join(ROOT, pkg_dir)
        if not os.path.isdir(base):
            continue
        for dirpath, _, files in os.walk(base):
            for f in files:
                if not f.endswith(".lean"):
                    continue
                path = os.path.join(dirpath, f)
                rel = os.path.relpath(path, os.path.join(ROOT, pkg_dir))
                mod = prefix + "." + rel[:-5].replace("/", ".")
                out[mod] = path
        top = os.path.join(ROOT, pkg_dir + ".lean")
        alt = os.path.join(os.path.dirname(base), prefix + ".lean")
        for candidate in (top, alt):
            if os.path.isfile(candidate):
                out[prefix] = candidate
    return out

def imports_of(path):
    found = []
    with open(path) as io:
        for line in io:
            m = re.match(r"^import\s+([A-Za-z0-9_.]+)", line)
            if m:
                found.append(m.group(1))
            elif line.strip() and not line.startswith("import"):
                break
    return found

def gather():
    mods = modules()
    edges = []
    for mod, path in sorted(mods.items()):
        if mod in AGGREGATORS:
            continue
        for imp in imports_of(path):
            if imp in AGGREGATORS:
                continue
            if imp.startswith("Mathlib"):
                continue
            edges.append((mod, imp))
    return mods, edges

def ranker_for(door, mods, edges):
    global SPINE
    if door in SPINES:
        SPINE = SPINES[door]
        return rank_of, len(SPINES[door])
    ranks = computed_ranks(door, set(mods) - AGGREGATORS, edges)
    nranks = len(set(ranks.values()))
    return ranks.get, nranks

def chart_defects(edges, ranker):
    defects = []
    unranked = set()
    for importer, imported in edges:
        ri, rj = ranker(importer), ranker(imported)
        if ri is None:
            unranked.add(importer)
            continue
        if rj is None:
            unranked.add(imported)
            continue
        if ri < rj:
            defects.append((importer, imported, ri, rj))
    return defects, unranked

def survey():
    mods, edges = gather()
    print("[foam gait — the hold survey: candidate tellings over one quiver]")
    print(f"  {'door':<10} {'ranks':>5} {'defect':>7}  reading")
    rows = [
        ("ledger", "the held telling (README spine)"),
        ("seat", "the observation door"),
        ("depth", "mechanical zero-defect (rank = import depth)"),
        ("flat", "the no-story telling (defect 0 by vacuity)"),
        ("reverse", "application first, floor last (the bound)"),
    ]
    for door, reading in rows:
        ranker, nranks = ranker_for(door, mods, edges)
        defects, _ = chart_defects(edges, ranker)
        print(f"  {door:<10} {nranks:>5} {len(defects):>7}  {reading}")
    print("  defect alone is gameable (see flat); a hold is good when it")
    print("  carries named, meant strata at low defect. the instrument")
    print("  proposes; a seat adjudicates (SPIRIT.md, bin/foam-judge).")

def main():
    door = "ledger"
    if "--doors" in sys.argv:
        survey()
        return
    if len(sys.argv) >= 3 and sys.argv[1] == "--door":
        door = sys.argv[2]
        if door not in SPINES and door not in COMPUTED_DOORS:
            avail = sorted(SPINES) + sorted(COMPUTED_DOORS)
            print(f"unknown door: {door} (available: {', '.join(avail)})")
            sys.exit(1)
    mods = modules()
    edges = []
    for mod, path in sorted(mods.items()):
        if mod in AGGREGATORS:
            continue
        for imp in imports_of(path):
            if imp in AGGREGATORS:
                continue
            if imp.startswith("Mathlib"):
                continue
            edges.append((mod, imp))

    receipts = 0
    for path in mods.values():
        with open(path) as io:
            receipts += io.read().count("#print axioms")

    ranker, _ = ranker_for(door, mods, edges)
    defects, unranked = chart_defects(edges, ranker)

    print("[foam gait]")
    print(f"  modules:   {len(mods)} ({len([m for m in mods if m not in AGGREGATORS])} ranked-checkable)")
    print(f"  edges:     {len(edges)} import edges (build chart: defect 0, compiler-enforced)")
    print(f"  receipts:  {receipts} `#print axioms` receipts standing")
    if door == "ledger":
        print(f"  narrative: defect {len(defects)} against the README spine")
    else:
        print(f"  narrative: defect {len(defects)} against the {door}-door telling")
    if defects:
        print("  the story's interface (edges the telling loops back across):")
        for importer, imported, ri, rj in sorted(defects):
            print(f"    {importer} (rank {ri}) ← {imported} (rank {rj})")
    if unranked:
        print(f"  unranked:  {len(unranked)} module(s) not on the spine map:")
        for m in sorted(unranked):
            print(f"    {m}")
        print("  (an unranked module is a sweep debt: seat it in SPINE when the story next moves)")

if __name__ == "__main__":
    main()
