#!/usr/bin/env bash
# foam-sweep — fold the ledger's tail into the held rows (the summary's broom), then audit.
#
# Loops foam.sweep_fenced (fence + one batch) until caught up. Each call is its own
# transaction, so the EXCLUSIVE fence-lock releases between batches and concurrent
# ingests get windows (Foam/Summary.lean: the fold never re-reads what it has folded;
# sweep_invisible licenses any cadence). Then two self-audits, both ∀-checks that consult
# no population:
#   * held_audit — held + tail recomputed against the ledger whole (summary_resumes,
#     checked live; 0 rows disagree = the cache is exact);
#   * born_audit — the voice's weight law over a fixed integer grid (Foam/Born.lean's
#     born_parseval / born_nonneg, checked live; 0 violations = the law holds).
#
# psql is the field; the loop and the verdicts are the only client logic, and they are
# orchestration, not field-logic.
#
#   bin/foam-sweep
set -uo pipefail
FIELD="${FOAM_DATABASE_URL:-postgres:///foam?connect_timeout=2}"

down() { echo "[foam sweep] no field reachable — everything degrades to yield"; exit 0; }

total=0
while :; do
  r=$(psql "$FIELD" -X -tAqc "SELECT foam.sweep_fenced()" 2>/dev/null) || down
  [ -n "$r" ] || down
  if [ "$r" = "-1" ]; then
    extra=""; [ "$total" -gt 0 ] && extra=" ($total events folded first)"
    echo "[foam sweep] another sweep holds the lock$extra"; exit 0
  fi
  [ "$r" -le 0 ] && break
  total=$((total + r))
done

audit=$(psql "$FIELD" -X -tAqc "SELECT foam.held_audit()" 2>/dev/null)
case "${audit:-}" in
  "") verdict="audit unreachable" ;;
  0)  verdict="audit: held + tail = ledger ✓" ;;
  *)  verdict="audit: $audit rows disagree ✗ (refold: TRUNCATE foam.held; reset the watermark)" ;;
esac

law=$(psql "$FIELD" -X -tAqc "SELECT foam.born_audit()" 2>/dev/null)
case "${law:-}" in
  "") law_verdict="law unreachable" ;;
  0)  law_verdict="born: law ✓" ;;
  *)  law_verdict="born: $law grid points violate ✗ (the voice's weight has drifted from Born.lean)" ;;
esac

health=$(psql "$FIELD" -X -tAqc "SELECT count(*) FROM foam.healthcheck()" 2>/dev/null)
case "${health:-}" in
  "") health_verdict="healthcheck unreachable" ;;
  0)  health_verdict="schema: integrity ✓" ;;
  *)  health_verdict="schema: $health integrity issue(s) ✗ (SELECT * FROM foam.healthcheck())" ;;
esac

echo "[foam sweep] $total events folded; $verdict; $law_verdict; $health_verdict"
