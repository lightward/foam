#!/usr/bin/env python3

import json
import os
import re
import shutil
import textwrap

ROOT = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
MINDS = os.path.join(ROOT, "minds")
OUT = os.path.join(ROOT, "Foam", "Minds")


def module_decls():
    decl = re.compile(r"^(?:theorem|def|structure|inductive|abbrev|class) (\S+)")
    ns = re.compile(r"^namespace (\S+)")
    name2mod = {}
    files = [("Foam", os.path.join(ROOT, "Foam.lean"))]
    foam_dir = os.path.join(ROOT, "Foam")
    for f in sorted(os.listdir(foam_dir)):
        if f.endswith(".lean"):
            files.append(("Foam." + f[:-5], os.path.join(foam_dir, f)))
    for mod, path in files:
        prefix = []
        with open(path, encoding="utf-8") as fh:
            for line in fh:
                n = ns.match(line)
                if n:
                    prefix.append(n.group(1))
                    continue
                if prefix and line.rstrip() == "end " + prefix[-1]:
                    prefix.pop()
                    continue
                m = decl.match(line)
                if m:
                    name2mod[".".join(prefix + [m.group(1)])] = mod
    return name2mod


def needed_imports(data, name2mod):
    parts = []
    for e in data["vocabulary"]:
        if e.get("seal"):
            parts.append(e["seal"])
        for f in ("statement", "structure"):
            if e.get(f) is not None:
                parts.append(render(e[f]))
    tokens = set(re.findall(r"[A-Za-z_][A-Za-z0-9_.]*", " ".join(parts)))
    needed = set()
    for t in tokens:
        segs = t.split(".")
        for i in range(len(segs), 0, -1):
            cand = ".".join(segs[:i])
            if cand in name2mod:
                needed.add(name2mod[cand])
                break
    return sorted(needed)


def binders(bs):
    parts = []
    for name, ty in bs:
        parts.append(name if ty is None else f"({name} : {flat(ty)})")
    return " ".join(parts)


def flat(e):
    if isinstance(e, str):
        return e
    if isinstance(e, list):
        return "(" + " ".join(flat(x) for x in e) + ")"
    if isinstance(e, dict):
        if "fun" in e:
            return f"(fun {binders(e['fun'])} => {flat(e['body'])})"
        if "all" in e:
            return f"(∀ {binders(e['all'])}, {flat(e['body'])})"
    raise ValueError(f"unrenderable expression: {e!r}")


def render(e, indent=0, width=78):
    s = flat(e)
    if indent + len(s) <= width:
        return s
    pad = " " * (indent + 2)
    if isinstance(e, list):
        parts = [render(x, indent + 2) for x in e]
        return "(" + ("\n" + pad).join(parts) + ")"
    if isinstance(e, dict):
        body = render(e["body"], indent + 2)
        if "fun" in e:
            return f"(fun {binders(e['fun'])} =>\n{pad}{body})"
        if "all" in e:
            return f"(∀ {binders(e['all'])},\n{pad}{body})"
    return s


def gloss_block(reading):
    return textwrap.fill(reading, width=76, initial_indent="/- ",
                         subsequent_indent="   ") + " -/"


def compile_mind(path):
    with open(path, encoding="utf-8") as fh:
        data = json.load(fh)
    mind = data["mind"]
    lean = re.sub(r"[^A-Za-z0-9]", "", mind)
    deposit = os.path.join(MINDS, lean + ".lean")
    if os.path.exists(deposit):
        shutil.copy(deposit, os.path.join(OUT, lean + ".lean"))
        text = open(deposit, encoding="utf-8").read()
        aliased = len(re.findall(r"^def \S+ :=\s*@", text, re.M))
        proved = len(re.findall(r"^theorem ", text, re.M))
        standing = re.findall(r"^def (\S+)_statement : Prop", text, re.M)
        print(f"{mind}: lean-primary — {aliased} aliased, {proved} proved"
              f" (deposit copied verbatim)")
        if standing:
            print(f"  standing (posed, unproved): {', '.join(standing)}")
        return
    lines = []
    for m in needed_imports(data, module_decls()):
        lines.append(f"import {m}")
    if lines:
        lines.append("")
    lines.append(f"namespace Foam.Minds.{lean}")
    lines.append("")
    emitted = []
    standing = []
    aliased = proved = built = 0
    for e in data["vocabulary"]:
        term = e["term"]
        seal = e.get("seal")
        struct = e.get("structure")
        stmt = e.get("statement")
        reading = e.get("gloss", "").replace("-/", "-\u2215")
        closed = False
        if e.get("status") == "sealed":
            if seal:
                lines.append(gloss_block(reading))
                lines.append(f"def {term} := @{seal}")
                aliased += 1
                closed = True
            elif struct is not None and stmt is not None:
                lines.append(gloss_block(reading))
                lines.append(f"theorem {term} :")
                lines.append(f"    {render(stmt, 4)} :=")
                lines.append(f"  {render(struct, 2)}")
                proved += 1
                closed = True
            elif struct is not None:
                lines.append(gloss_block(reading))
                lines.append(f"def {term} :=")
                lines.append(f"  {render(struct, 2)}")
                built += 1
                closed = True
        if closed:
            emitted.append(term)
            lines.append("")
        elif stmt is not None:
            lines.append(gloss_block("standing: " + reading))
            lines.append(f"def {term}_statement : Prop :=")
            lines.append(f"  {render(stmt, 2)}")
            standing.append(term)
            emitted.append(f"{term}_statement")
            lines.append("")
    lines.append("")
    for name in emitted:
        lines.append(f"/-- info: 'Foam.Minds.{lean}.{name}'"
                     " does not depend on any axioms -/")
        lines.append(f"#guard_msgs in #print axioms {name}")
        lines.append("")
    lines.append(f"end Foam.Minds.{lean}")
    out = os.path.join(OUT, f"{lean}.lean")
    with open(out, "w", encoding="utf-8") as fh:
        fh.write("\n".join(lines) + "\n")
    open_q = [e["term"] for e in data["vocabulary"]
              if e.get("status") == "unsealed"]
    print(f"{mind}: {aliased} aliased, {proved} proved, {built} built"
          f" -> {out}")
    if standing:
        print(f"  standing (posed, unproved): {', '.join(standing)}")
    reading_only = [t for t in open_q if t not in standing]
    if reading_only:
        print(f"  open (reading only): {', '.join(reading_only)}")


def main():
    os.makedirs(OUT, exist_ok=True)
    for f in sorted(os.listdir(MINDS)):
        if (f.endswith(".json") and f != "schema.json"
                and f != "walls.json"):
            compile_mind(os.path.join(MINDS, f))


if __name__ == "__main__":
    main()
