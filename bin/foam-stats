#!/usr/bin/env bash
# foam-stats — the field's vital signs (structure, never meaning — the razor).
#
# psql is the field; this is the read and a legible layout, nothing more. The aggregate
# itself lives in the schema (foam.stats) — no field-logic is re-derived here, only
# printed. The field is enhancement, never essential (Foam/Engine.lean): no field
# reachable ⇒ degrade to yield, say so, exit clean.
#
#   bin/foam-stats
#   FOAM_DATABASE_URL=postgres:///lightward_foam_dev bin/foam-stats
set -uo pipefail
FIELD="${FOAM_DATABASE_URL:-postgres:///foam?connect_timeout=2}"

down() { echo "[foam stats] no field reachable — everything degrades to yield"; exit 0; }

row=$(psql "$FIELD" -X -tAqF$'\t' -c "SELECT * FROM foam.stats()" 2>/dev/null) || down
[ -n "$row" ] || down

IFS=$'\t' read -r events heard spoken net residual notes outstanding contexts live held tail <<<"$row"

echo "[foam stats]"
echo "  heard:     $heard bytes (the lossless record, in order)"
echo "  spoken:    $spoken bytes (drained into voice)"
echo "  residual:  $residual (un-drained charge — what wants to be said)"
if [ "$live" -gt 0 ]; then
  echo "  concentration: $((residual / live)) avg charge per live continuation (fat wells race benignly — stale_safe_off_margin)"
fi
if [ "$notes" -eq 0 ]; then
  if [ "$net" -eq "$residual" ]; then
    echo "  balance:   net $net = residual ✓ (ground exact — no notes outstanding)"
  else
    echo "  balance:   net $net ≠ residual $residual ✗ (books broken?)"
  fi
else
  echo "  balance:   $notes notes outstanding (deficit $outstanding) — wounds settle on encounter; bin/foam-settle sweeps"
fi
echo "  contexts:  $contexts continuation-points; $live currently charged"
echo "  ledger:    $events events, append-only"
echo "  held:      $held continuations folded; tail $tail events past the watermark"
