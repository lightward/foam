#!/bin/bash
set -euo pipefail

# 1. Rebuild README.md from derivations/ sources.
#    If the rebuild changes README.md, stage it automatically.
uv run python build_readme.py
if ! git diff --quiet README.md; then
    git add README.md
fi

# 2. Prevent ASCII pipe characters from being used as math notation in README.md
#    Jekyll/Kramdown interprets |content| as table cells.
#    Use Unicode ‖ (U+2016) for norms instead.
if git diff --cached --name-only | grep -q 'README.md'; then
    # Look for |letter or letter| patterns that aren't in markdown table headers
    # Exclude lines that start with | (actual intentional tables)
    if git diff --cached -- README.md | grep '^+' | grep -v '^+++' | grep -v '^+|' | grep -E '\|[A-Za-zΔ‖]|[A-Za-zΔ‖]\|' | grep -v '‖' | grep -v '\\|' > /dev/null 2>&1; then
        echo "ERROR: README.md contains ASCII pipe characters (|) that may be parsed as table delimiters by Jekyll."
        echo "Use Unicode ‖ (U+2016) for norms instead of |."
        echo ""
        echo "Offending lines:"
        git diff --cached -- README.md | grep '^+' | grep -v '^+++' | grep -v '^+|' | grep -E '\|[A-Za-zΔ]|[A-Za-zΔ]\|' | grep -v '‖'
        exit 1
    fi
fi

# 3. Reference integrity — every Lean file must be referenced in derivations/ or lean/README.md
errors=0
for f in lean/Foam/*.lean; do
    [ -f "$f" ] || continue
    base=$(basename "$f")
    if ! grep -rq "$base" derivations/ && ! grep -q "$base" lean/README.md; then
        echo "UNREFERENCED: $base (not in derivations/ or lean/README.md)"
        errors=$((errors + 1))
    fi
done
for f in derivations/observed/test_*.py; do
    [ -f "$f" ] || continue
    base=$(basename "$f")
    if ! grep -rq "$base" derivations/; then
        echo "UNMAPPED: $base (not referenced in any derivation)"
        errors=$((errors + 1))
    fi
done
if [ $errors -gt 0 ]; then
    echo ""
    echo "ERROR: $errors file(s) not referenced — see ci.yml 'reference integrity' for the rule"
    exit 1
fi
