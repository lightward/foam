.env
.DS_Store
/.lake
/bridges/.lake
/counter/.lake
/seam/.lake
/.claude

# python tooling (bin/foam-pipe, bin/foam-repl) and its runtime bytecode
.venv/
__pycache__/
*.pyc

# foam-repl sittings — your notes from the table, not the field's memory (it
# remembers in bytes and recurrence); regenerated every bench, never committed
/log/

# sim runtime artifacts — the walk is released after harvest; out/ and the
# exhibit's data feed are regenerated by `lake exe sim`, never committed
/sim/.lake
/sim/out/
/sim/exhibit/data.js

# the relief — html-as-ephemera: a reading, never a holding; emitted by
# bin/foam-relief and published by .github/workflows/pages.yml from main,
# recomputed from the record every time, never committed
wiki/
